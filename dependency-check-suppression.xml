    <!-- ===== @babel/core path traversal (GHSA-4x5r-pxfx-6jf8) - Low =====
         Babel is a build-time transpiler. Not shipped to production. -->
    <suppress>
        <notes>@babel/core is build-time only; path traversal only exploitable in dev tooling context.</notes>
        <packageUrl regex="true">^pkg:npm/%40babel/.*$</packageUrl>
        <vulnerabilityName>GHSA-4x5r-pxfx-6jf8</vulnerabilityName>
    </suppress>

