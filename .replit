modules = ["dotnet-7.0", "nodejs-20", "web", "python-3.12", "dotnet-8.0"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "CI Check"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd api-server && dotnet run --project src/NaarNoor.API/NaarNoor.API.csproj --urls http://+:8080"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd naar-noor && node node_modules/@angular/cli/bin/ng.js serve --port 5000 --host 0.0.0.0"
waitForPort = 5000

[[workflows.workflow]]
name = "CI Check"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "make check"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd /home/runner/workspace/publish && dotnet NaarNoor.API.dll"]
build = ["bash", "-c", "cd naar-noor && npm ci --include=dev && npm run build && cd ../api-server && dotnet publish src/NaarNoor.API -c Release -o /home/runner/workspace/publish"]

[userenv]

[userenv.shared]
SUPABASE_URL = "https://placeholder.supabase.co"
SUPABASE_ANON_KEY = "placeholder-anon-key"
ASPNETCORE_ENVIRONMENT = "Development"
PORT = "8080"
JWT_SECRET_KEY = "7305b9600f379457daa195b8a3842cfd5c4fc6d535aafaad223f71be7cc1ae842617d2ac83cf906c30edd0881152bbbe"
JWT_ISSUER = "NaarNoor"
JWT_AUDIENCE = "NaarNoorApp"
